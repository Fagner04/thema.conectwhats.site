{%- comment -%} BARRA DE PROGRESSO ATACADO + CÁLCULO TOTAL {%- endcomment -%}
{%- if settings.conectwhats_atacado_enabled -%}
{%- assign wholesale_min = settings.conectwhats_atacado_min_qty | default: 6 -%}
{%- assign total_items = cart.item_count -%}
{%- assign progress = total_items | times: 100 | divided_by: wholesale_min -%}
{%- if progress > 100 -%}
  {%- assign progress = 100 -%}
{%- endif -%}
{%- assign remaining = wholesale_min | minus: total_items -%}
{%- assign wholesale_active = false -%}
{%- if remaining <= 0 -%}
  {%- assign wholesale_active = true -%}
{%- endif -%}

{%- comment -%} CALCULAR TOTAL COM PREÇOS DE ATACADO {%- endcomment -%}
{%- assign wholesale_total = 0 -%}
{%- assign original_total = 0 -%}
{%- assign has_wholesale_prices = false -%}

{%- if wholesale_active -%}
  {%- for item in cart.items -%}
    {%- assign ws_price = item.product.metafields.custom.wholesale_price.value -%}
    {%- unless ws_price -%}
      {%- assign ws_price = item.product.metafields.custom.wholesale_price -%}
    {%- endunless -%}
    
    {%- if ws_price and ws_price > 0 -%}
      {%- assign has_wholesale_prices = true -%}
      {%- if ws_price < 1000 -%}
        {%- assign ws_price_cents = ws_price | times: 100 -%}
      {%- else -%}
        {%- assign ws_price_cents = ws_price -%}
      {%- endif -%}
      {%- assign item_ws_total = ws_price_cents | times: item.quantity -%}
      {%- assign wholesale_total = wholesale_total | plus: item_ws_total -%}
      {%- assign original_total = original_total | plus: item.final_line_price -%}
    {%- else -%}
      {%- assign wholesale_total = wholesale_total | plus: item.final_line_price -%}
      {%- assign original_total = original_total | plus: item.final_line_price -%}
    {%- endif -%}
  {%- endfor -%}
  
  {%- assign savings = original_total | minus: wholesale_total -%}
{%- endif -%}

<style>
.cw-new-total {
  background: white;
  border: 1.5px solid #BBF7D0;
  border-radius: 14px;
  padding: 14px 16px;
  margin: 12px 0 0;
  box-shadow: 0 2px 8px rgba(34,197,94,0.08), 0 1px 3px rgba(0,0,0,0.06);
}
.cw-new-total-label {
  font-size: 12px;
  color: #166534;
  margin: 0 0 6px;
  font-weight: 700;
  display: flex;
  align-items: center;
  gap: 6px;
}
.cw-new-total-price {
  font-size: 22px;
  font-weight: 800;
  color: #15803D;
  margin: 0 0 6px;
  letter-spacing: -0.5px;
}
.cw-badge-atacado {
  display: inline-flex;
  align-items: center;
  gap: 3px;
  background: #DCFCE7;
  color: #166534;
  font-size: 10px;
  padding: 2px 7px;
  border-radius: 99px;
  font-weight: 700;
  margin-left: 4px;
  border: 1px solid #86EFAC;
  width: fit-content;
  max-width: 90px;
  white-space: nowrap;
}
.cw-wholesale-progress {
  font-family: inherit;
  background: white !important;
  border: 1.5px solid #E5E7EB !important;
  border-radius: 16px !important;
  box-shadow: 0 4px 16px rgba(0,0,0,0.07), 0 1px 4px rgba(0,0,0,0.05) !important;
  padding: 14px 16px !important;
  margin: 0 0 16px !important;
}
.cw-progress-header {
  display: flex;
  align-items: center;
  gap: 8px;
}
.cw-progress-icon {
  width: 36px;
  height: 36px;
  border-radius: 10px;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}
.cw-progress-icon--active {
  background: linear-gradient(135deg, #22C55E, #16A34A);
  box-shadow: 0 3px 8px rgba(34,197,94,0.35);
}
.cw-progress-icon--pending {
  background: linear-gradient(135deg, #F59E0B, #D97706);
  box-shadow: 0 3px 8px rgba(245,158,11,0.35);
}
.cw-progress-icon svg {
  width: 18px;
  height: 18px;
  stroke: white;
  fill: none;
  stroke-width: 2.5;
  stroke-linecap: round;
  stroke-linejoin: round;
}
.cw-savings-row {
  display: flex;
  align-items: center;
  gap: 5px;
  font-size: 11px;
  color: #166534;
  margin: 3px 0 0;
}
.cw-savings-row svg {
  width: 13px;
  height: 13px;
  stroke: #16A34A;
  fill: none;
  stroke-width: 2.5;
  stroke-linecap: round;
  stroke-linejoin: round;
  flex-shrink: 0;
}

/* Responsivo para mobile */
@media (max-width: 768px) {
  .cw-wholesale-progress {
    padding: 8px 10px !important;
    margin: 8px 0 !important;
    font-size: 11px;
  }
  .cw-new-total { padding: 10px; margin: 10px 0; }
  .cw-new-total-price { font-size: 17px; }
  .cw-badge-atacado { font-size: 8px !important; padding: 1px 5px !important; margin-left: 2px !important; }
  .line-item__price-list { display: flex !important; flex-direction: column !important; gap: 2px !important; align-items: flex-start !important; }
  .line-item__price-list .line-item__price--compare { font-size: 11px !important; display: block !important; }
  .line-item__price-list .line-item__price--highlight { font-size: 13px !important; display: block !important; }
  .mini-cart__price-list { display: flex !important; flex-direction: column !important; gap: 2px !important; }
  .mini-cart__price-list .price--compare { font-size: 11px !important; }
  .mini-cart__price-list .price--highlight { font-size: 13px !important; }
  [data-line-total] span { font-size: 12px !important; }
}

/* Tablet */
@media (min-width: 769px) and (max-width: 1024px) {
  .cw-wholesale-progress { padding: 10px 12px !important; }
  .cw-new-total-price { font-size: 18px; }
  .cw-badge-atacado { font-size: 9px !important; }
}
</style>

<div class="cw-wholesale-progress">
  {%- if wholesale_active -%}
    <div class="cw-progress-header">
      <div class="cw-progress-icon cw-progress-icon--active">
        <!-- Lucide: tag -->
        <svg viewBox="0 0 24 24"><path d="M12 2H7a2 2 0 0 0-2 2v5l9.29 9.29a2 2 0 0 0 2.83 0l4.88-4.88a2 2 0 0 0 0-2.83L12 2z"/><circle cx="7.5" cy="7.5" r="1.5" fill="white" stroke="none"/></svg>
      </div>
      <div style="flex:1;">
        <p style="font-size: 13px; font-weight: 800; color: #15803D; margin: 0; display:flex; align-items:center; gap:5px;">
          <!-- Lucide: check-circle -->
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#16A34A" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="m9 12 2 2 4-4"/></svg>
          Atacado Ativo!
        </p>
        <p style="font-size: 11px; color: #166534; margin: 2px 0 0; display:flex; align-items:center; gap:4px;">
          <!-- Lucide: trending-down -->
          <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#16A34A" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="23 18 13.5 8.5 8.5 13.5 1 6"/><polyline points="17 18 23 18 23 12"/></svg>
          Você está economizando com preços de atacado!
        </p>
      </div>
      <span style="font-size: 12px; font-weight: 700; color: #15803D; background: #DCFCE7; padding: 3px 8px; border-radius: 99px; border: 1px solid #86EFAC; white-space: nowrap;">{{ total_items }}/{{ wholesale_min }} peças</span>
    </div>
    <div style="width: 100%; height: 7px; background: #BBF7D0; border-radius: 99px; overflow: hidden; margin-top: 10px;">
      <div style="width: 100%; height: 100%; background: linear-gradient(90deg, #22C55E, #16A34A); border-radius: 99px;"></div>
    </div>

    {%- if has_wholesale_prices and wholesale_total > 0 -%}
    {%- endif -%}
  {%- else -%}
    <div class="cw-progress-header" style="margin-bottom: 8px;">
      <div class="cw-progress-icon cw-progress-icon--pending">
        <!-- Lucide: shopping-cart -->
        <svg viewBox="0 0 24 24"><circle cx="9" cy="21" r="1"/><circle cx="20" cy="21" r="1"/><path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"/></svg>
      </div>
      <div style="flex:1;">
        <p style="font-size: 12px; font-weight: 700; color: #92400E; margin: 0; display:flex; align-items:center; gap:4px;">
          <!-- Lucide: lock -->
          <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#B45309" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
          Faltam <strong style="color: #C2410C; margin: 0 2px;">{{ remaining }}</strong> peça(s) para atacado!
        </p>
        <p style="font-size: 10px; color: #B45309; margin: 2px 0 0;">Adicione mais itens e pague preço de atacado</p>
      </div>
      <span style="font-size: 11px; color: #B45309; font-weight: 600; background: #FEF3C7; padding: 3px 8px; border-radius: 99px; border: 1px solid #FDE68A; white-space: nowrap;">{{ total_items }}/{{ wholesale_min }}</span>
    </div>
    <div style="width: 100%; height: 7px; background: #FDE68A; border-radius: 99px; overflow: hidden;">
      <div style="width: {{ progress }}%; height: 100%; background: linear-gradient(90deg, #F59E0B, #D97706); border-radius: 99px; transition: width 0.4s ease;"></div>
    </div>
  {%- endif -%}
</div>

<script>
(function() {
  var wholesaleActive = {{ wholesale_active | json }};
  var hasWholesalePrices = {{ has_wholesale_prices | json }};
  
  {%- comment -%} Verifica mínimo de acessórios {%- endcomment -%}
  var acessorioMinEnabled = {{ settings.acessorio_min_enabled | json }};
  var acessorioTag = {{ settings.acessorio_min_tag | default: '' | strip | downcase | json }};
  var acessorioMinCents = {{ settings.acessorio_min_value | plus: 0 | times: 100 | round | json }};
  var acessorioTotalCents = 0;
  {%- if settings.acessorio_min_enabled -%}
    {%- assign acessorio_tag_js = settings.acessorio_min_tag | strip | downcase -%}
    {%- for item in cart.items -%}
      {%- assign item_tags_js = item.product.tags | join: ',' | downcase -%}
      {%- if item_tags_js contains acessorio_tag_js -%}
        acessorioTotalCents += {{ item.final_line_price | json }};
      {%- endif -%}
    {%- endfor -%}
  {%- endif -%}
  var acessorioReached = acessorioMinEnabled ? (acessorioTotalCents >= acessorioMinCents) : true;

  // Mapa de tags por produto
  var productTags = {};
  {%- for item in cart.items -%}
    productTags['{{ item.product.id }}'] = {{ item.product.tags | join: ',' | downcase | json }};
  {%- endfor -%}

  function isAcessorio(productId) {
    if (!acessorioMinEnabled || !acessorioTag) return false;
    var tags = productTags[productId] || '';
    return tags.indexOf(acessorioTag) !== -1;
  }

  if (wholesaleActive && hasWholesalePrices) {
    // Criar mapa de preços de atacado por produto
    var wholesalePrices = {};
    {%- for item in cart.items -%}
      {%- assign ws_price = item.product.metafields.custom.wholesale_price.value -%}
      {%- unless ws_price -%}
        {%- assign ws_price = item.product.metafields.custom.wholesale_price -%}
      {%- endunless -%}
      {%- if ws_price and ws_price > 0 -%}
        {%- if ws_price < 1000 -%}
          {%- assign ws_price_cents = ws_price | times: 100 -%}
        {%- else -%}
          {%- assign ws_price_cents = ws_price -%}
        {%- endif -%}
        {%- assign item_ws_total = ws_price_cents | times: item.quantity -%}
        wholesalePrices['{{ item.product.id }}'] = {
          unitPrice: {{ ws_price_cents | json }},
          quantity: {{ item.quantity | json }},
          total: {{ item_ws_total | json }},
          originalTotal: {{ item.final_line_price | json }}
        };
      {%- endif -%}
    {%- endfor -%}
    
    function formatMoney(cents) {
      return 'R$ ' + (cents / 100).toFixed(2).replace('.', ',');
    }
    
    function updateProductPrices() {
      // Detectar se está em mobile
      var isMobile = window.innerWidth <= 768;
      
      // Atualizar preços de cada produto no mini-cart
      var priceElements = document.querySelectorAll('[data-line-item-price]');
      
      priceElements.forEach(function(priceEl) {
        var productId = priceEl.getAttribute('data-product-id');
        
        if (wholesalePrices[productId]) {
          // Se é acessório e não atingiu o mínimo de valor, não aplica atacado
          if (isAcessorio(productId) && !acessorioReached) return;

          var wsData = wholesalePrices[productId];
          var newHTML = '';
          
          // Container flex para alinhar preços
          newHTML += '<div style="display: flex; flex-direction: column; gap: 2px;">';
          
          // Preço original riscado
          newHTML += '<span class="price price--compare" style="text-decoration: line-through; color: #9CA3AF; font-size: ' + (isMobile ? '11px' : '13px') + ';">';
          newHTML += formatMoney(wsData.originalTotal);
          newHTML += '</span>';
          
          // Preço de atacado em verde
          newHTML += '<span class="price price--highlight" style="color: #16A34A; font-weight: 700; font-size: ' + (isMobile ? '13px' : '15px') + ';">';
          newHTML += formatMoney(wsData.total);
          newHTML += '</span>';
          
          newHTML += '</div>';
          
          // Badge atacado - só mostra se não é acessório ou se atingiu o mínimo
          if (!isAcessorio(productId) || acessorioReached) {
            newHTML += '<span class="cw-badge-atacado" style="margin-top: 2px;">🏷 Atacado</span>';
          }
          
          priceEl.innerHTML = newHTML;
        }
      });
      
      // Atualizar preço unitário na coluna "Produto" da página do carrinho (desktop e mobile)
      var productRows = document.querySelectorAll('tr[data-line-item-key]');
      
      productRows.forEach(function(row) {
        var productId = row.getAttribute('data-product-id');
        
        if (wholesalePrices[productId]) {
          if (isAcessorio(productId) && !acessorioReached) return;

          var wsData = wholesalePrices[productId];
          
          // Encontrar TODOS os elementos de preço (desktop e mobile)
          var unitPriceElements = row.querySelectorAll('.line-item__price-list');
          
          unitPriceElements.forEach(function(unitPriceEl) {
            var newHTML = '';
            
            // Preço unitário original riscado (inline)
            newHTML += '<div style="margin-bottom: 2px;"><span class="line-item__price line-item__price--compare" style="text-decoration: line-through; color: #9CA3AF; font-size: ' + (isMobile ? '11px' : '13px') + ';">';
            newHTML += formatMoney(wsData.originalTotal);
            newHTML += '</span></div>';
            
            // Preço de atacado total em verde (inline)
            newHTML += '<div style="margin-bottom: 2px;"><span class="line-item__price line-item__price--highlight" style="color: #16A34A; font-weight: 700; font-size: ' + (isMobile ? '13px' : '15px') + ';">';
            newHTML += formatMoney(wsData.total);
            newHTML += '</span></div>';
            
            // Badge atacado
            if (!isAcessorio(productId) || acessorioReached) {
              newHTML += '<span class="cw-badge-atacado">🏷 Atacado</span>';
            }
            
            unitPriceEl.innerHTML = newHTML;
          });
        }
      });
      
      // Atualizar coluna "Total" na página do carrinho (apenas desktop - hidden-phone)
      var totalCells = document.querySelectorAll('[data-line-total]');
      
      totalCells.forEach(function(totalCell) {
        var productId = totalCell.getAttribute('data-product-id');
        
        if (wholesalePrices[productId]) {
          if (isAcessorio(productId) && !acessorioReached) return;

          var wsData = wholesalePrices[productId];
          var newHTML = '';
          
          // Preço original riscado (inline)
          newHTML += '<div style="margin-bottom: 4px;"><span style="text-decoration: line-through; color: #9CA3AF; font-size: ' + (isMobile ? '11px' : '13px') + ';">';
          newHTML += formatMoney(wsData.originalTotal);
          newHTML += '</span></div>';
          
          // Preço de atacado em verde (inline)
          newHTML += '<div style="margin-bottom: 4px;"><span style="color: #16A34A; font-weight: 700; font-size: ' + (isMobile ? '14px' : '16px') + ';">';
          newHTML += formatMoney(wsData.total);
          newHTML += '</span></div>';
          
          // Badge atacado
          if (!isAcessorio(productId) || acessorioReached) {
            newHTML += '<span class="cw-badge-atacado">🏷 Atacado</span>';
          }
          
          totalCell.innerHTML = newHTML;
        }
      });
      
      // Atualizar o TOTAL GERAL do mini-cart
      var miniCartTotal = document.getElementById('mini-cart-total-price');
      if (miniCartTotal) {
        var wholesaleTotal = {{ wholesale_total | json }};
        var originalTotal = {{ original_total | json }};
        
        if (wholesaleTotal > 0 && wholesaleTotal < originalTotal) {
          var newHTML = '';
          
          // Total original riscado (inline)
          newHTML += '<div style="margin-bottom: 2px;"><span style="text-decoration: line-through; color: #9CA3AF; font-size: ' + (isMobile ? '12px' : '14px') + ';">';
          newHTML += formatMoney(originalTotal);
          newHTML += '</span></div>';
          
          // Total com atacado em verde
          newHTML += '<span style="color: #16A34A; font-weight: 700; font-size: ' + (isMobile ? '16px' : '18px') + ';">';
          newHTML += formatMoney(wholesaleTotal);
          newHTML += '</span>';
          
          miniCartTotal.innerHTML = newHTML;
        }
      }
      
      // Atualizar o TOTAL GERAL da página do carrinho
      var cartTotal = document.getElementById('cart-total-original');
      if (cartTotal) {
        var wholesaleTotal = {{ wholesale_total | json }};
        var originalTotal = {{ original_total | json }};
        
        if (wholesaleTotal > 0 && wholesaleTotal < originalTotal) {
          var newHTML = '';
          
          // Total original riscado (inline)
          newHTML += '<div style="margin-bottom: 2px;"><span style="text-decoration: line-through; color: #9CA3AF; font-size: ' + (isMobile ? '13px' : '15px') + ';">';
          newHTML += formatMoney(originalTotal);
          newHTML += '</span></div>';
          
          // Total com atacado em verde
          newHTML += '<span style="color: #16A34A; font-weight: 700; font-size: ' + (isMobile ? '18px' : '20px') + ';">';
          newHTML += formatMoney(wholesaleTotal);
          newHTML += '</span>';
          
          cartTotal.innerHTML = newHTML;
        }
      }
    }
    
    // Executar quando carregar
    setTimeout(updateProductPrices, 100);
    setTimeout(updateProductPrices, 500);
    
    // Atualizar ao redimensionar (rotação de tela mobile)
    var resizeTimer;
    window.addEventListener('resize', function() {
      clearTimeout(resizeTimer);
      resizeTimer = setTimeout(function() {
        updateProductPrices();
      }, 250);
    });
    
    // Observar mudanças no carrinho
    var observer = new MutationObserver(function() {
      setTimeout(updateProductPrices, 200);
    });
    
    var miniCart = document.querySelector('.mini-cart');
    if (miniCart) {
      observer.observe(miniCart, { childList: true, subtree: true });
    }
    
    var cartWrapper = document.querySelector('.cart-wrapper');
    if (cartWrapper) {
      observer.observe(cartWrapper, { childList: true, subtree: true });
    }
  }
})();
</script>
{%- endif -%}
