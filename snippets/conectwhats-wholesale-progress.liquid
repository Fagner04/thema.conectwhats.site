{%- comment -%} BARRA DE PROGRESSO ATACADO + CÁLCULO TOTAL {%- endcomment -%}
{%- if settings.conectwhats_atacado_enabled -%}
{%- assign wholesale_min = settings.conectwhats_atacado_min_qty | default: 6 -%}
{%- assign total_items = cart.item_count -%}
{%- assign progress = total_items | times: 100 | divided_by: wholesale_min -%}
{%- if progress > 100 -%}
  {%- assign progress = 100 -%}
{%- endif -%}
{%- assign remaining = wholesale_min | minus: total_items -%}
{%- assign wholesale_active = false -%}
{%- if remaining <= 0 -%}
  {%- assign wholesale_active = true -%}
{%- endif -%}

{%- comment -%} CALCULAR TOTAL COM PREÇOS DE ATACADO {%- endcomment -%}
{%- assign wholesale_total = 0 -%}
{%- assign original_total = 0 -%}
{%- assign has_wholesale_prices = false -%}

{%- if wholesale_active -%}
  {%- for item in cart.items -%}
    {%- assign ws_price = item.product.metafields.custom.wholesale_price.value -%}
    {%- unless ws_price -%}
      {%- assign ws_price = item.product.metafields.custom.wholesale_price -%}
    {%- endunless -%}
    
    {%- if ws_price and ws_price > 0 -%}
      {%- assign has_wholesale_prices = true -%}
      {%- if ws_price < 1000 -%}
        {%- assign ws_price_cents = ws_price | times: 100 -%}
      {%- else -%}
        {%- assign ws_price_cents = ws_price -%}
      {%- endif -%}
      {%- assign item_ws_total = ws_price_cents | times: item.quantity -%}
      {%- assign wholesale_total = wholesale_total | plus: item_ws_total -%}
      {%- assign original_total = original_total | plus: item.final_line_price -%}
    {%- else -%}
      {%- assign wholesale_total = wholesale_total | plus: item.final_line_price -%}
      {%- assign original_total = original_total | plus: item.final_line_price -%}
    {%- endif -%}
  {%- endfor -%}
  
  {%- assign savings = original_total | minus: wholesale_total -%}
{%- endif -%}

<style>
.cw-wholesale-progress {
  font-family: inherit;
  border-radius: 14px;
  overflow: hidden;
  margin: 0 0 14px;
}

/* === ESTADO ATIVO === */
.cw-card-active {
  background: linear-gradient(135deg, #f0fdf4 0%, #dcfce7 100%);
  border: 1.5px solid #86EFAC;
  border-radius: 14px;
  padding: 14px 16px 12px;
}
.cw-card-active-top {
  display: flex;
  align-items: center;
  gap: 8px;
  flex-wrap: nowrap;
  min-width: 0;
}
.cw-icon-wrap-active {
  width: 42px;
  height: 42px;
  border-radius: 12px;
  background: linear-gradient(135deg, #22C55E, #15803D);
  box-shadow: 0 4px 12px rgba(34,197,94,0.4);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}
.cw-icon-wrap-active svg {
  width: 20px; height: 20px;
  stroke: #fff; fill: none;
  stroke-width: 2.2; stroke-linecap: round; stroke-linejoin: round;
}
.cw-active-title {
  font-size: 13px;
  font-weight: 800;
  color: #14532D;
  margin: 0 0 2px;
  letter-spacing: -0.2px;
  white-space: nowrap;
}
.cw-active-sub {
  font-size: 10px;
  color: #166534;
  margin: 0;
  line-height: 1.4;
  white-space: nowrap;
}
.cw-active-text {
  min-width: 0;
  flex: 1;
  overflow: hidden;
}
.cw-badge-count {
  margin-left: auto;
  flex-shrink: 0;
  background: #16A34A;
  color: #fff;
  font-size: 12px;
  font-weight: 700;
  padding: 4px 10px;
  border-radius: 99px;
  white-space: nowrap;
  box-shadow: 0 2px 6px rgba(22,163,74,0.35);
}
.cw-bar-wrap-active {
  margin-top: 10px;
  height: 6px;
  background: #BBF7D0;
  border-radius: 99px;
  overflow: hidden;
}
.cw-bar-fill-active {
  height: 100%;
  width: 100%;
  background: linear-gradient(90deg, #4ADE80, #16A34A);
  border-radius: 99px;
}

/* === ESTADO PENDENTE === */
.cw-card-pending {
  background: #fff;
  border: 1.5px solid #E5E7EB;
  border-radius: 14px;
  padding: 14px 16px 12px;
  box-shadow: 0 2px 8px rgba(0,0,0,0.05);
}
.cw-card-pending-top {
  display: flex;
  align-items: center;
  gap: 12px;
}
.cw-icon-wrap-pending {
  width: 42px;
  height: 42px;
  border-radius: 12px;
  background: linear-gradient(135deg, #FCD34D, #D97706);
  box-shadow: 0 4px 12px rgba(217,119,6,0.35);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}
.cw-icon-wrap-pending svg {
  width: 20px; height: 20px;
  stroke: #fff; fill: none;
  stroke-width: 2.2; stroke-linecap: round; stroke-linejoin: round;
}
.cw-pending-title {
  font-size: 13px;
  font-weight: 700;
  color: #1F2937;
  margin: 0 0 2px;
}
.cw-pending-sub {
  font-size: 11px;
  color: #6B7280;
  margin: 0;
  line-height: 1.4;
}
.cw-badge-remaining {
  margin-left: auto;
  flex-shrink: 0;
  background: #FEF3C7;
  color: #92400E;
  font-size: 12px;
  font-weight: 700;
  padding: 4px 10px;
  border-radius: 99px;
  border: 1px solid #FDE68A;
  white-space: nowrap;
}
.cw-bar-wrap-pending {
  margin-top: 10px;
  height: 6px;
  background: #F3F4F6;
  border-radius: 99px;
  overflow: hidden;
}
.cw-bar-fill-pending {
  height: 100%;
  background: linear-gradient(90deg, #FCD34D, #F59E0B);
  border-radius: 99px;
  transition: width 0.4s ease;
}
.cw-bar-labels {
  display: flex;
  justify-content: space-between;
  margin-top: 5px;
}
.cw-bar-labels span {
  font-size: 10px;
  color: #9CA3AF;
  font-weight: 500;
}
</style>

<div class="cw-wholesale-progress">
  {%- if wholesale_active -%}
    <div class="cw-card-active">
      <div class="cw-card-active-top">
        <div class="cw-icon-wrap-active">
          <svg viewBox="0 0 24 24"><path d="M20.59 13.41l-7.17 7.17a2 2 0 0 1-2.83 0L2 12V2h10l8.59 8.59a2 2 0 0 1 0 2.82z"/><line x1="7" y1="7" x2="7.01" y2="7"/></svg>
        </div>
        <div class="cw-active-text">
          <p class="cw-active-title">✓ Atacado Ativo!</p>
          <p class="cw-active-sub">Você está pagando preço de atacado</p>
        </div>
        <span class="cw-badge-count">{{ total_items }}/{{ wholesale_min }} peças</span>
      </div>
      <div class="cw-bar-wrap-active">
        <div class="cw-bar-fill-active"></div>
      </div>
    </div>
  {%- else -%}
    <div class="cw-card-pending">
      <div class="cw-card-pending-top">
        <div class="cw-icon-wrap-pending">
          <svg viewBox="0 0 24 24"><circle cx="9" cy="21" r="1"/><circle cx="20" cy="21" r="1"/><path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"/></svg>
        </div>
        <div>
          <p class="cw-pending-title">Faltam <strong style="color:#D97706;">{{ remaining }} peça{% if remaining != 1 %}s{% endif %}</strong> para atacado</p>
          <p class="cw-pending-sub">Adicione mais itens e economize!</p>
        </div>
        <span class="cw-badge-remaining">{{ total_items }}/{{ wholesale_min }}</span>
      </div>
      <div class="cw-bar-wrap-pending">
        <div class="cw-bar-fill-pending" style="width:{{ progress }}%;"></div>
      </div>
      <div class="cw-bar-labels">
        <span>{{ total_items }} peça{% if total_items != 1 %}s{% endif %}</span>
        <span>Meta: {{ wholesale_min }} peças</span>
      </div>
    </div>
  {%- endif -%}
</div>

<script>
(function() {
  function formatMoney(cents) {
    return 'R$ ' + (cents / 100).toFixed(2).replace('.', ',');
  }

  // Mapa de preços de atacado por produto (do Liquid)
  var wholesalePriceMap = {};
  {%- for item in cart.items -%}
    {%- assign ws_price = item.product.metafields.custom.wholesale_price.value -%}
    {%- unless ws_price -%}{%- assign ws_price = item.product.metafields.custom.wholesale_price -%}{%- endunless -%}
    {%- if ws_price and ws_price > 0 -%}
      {%- if ws_price < 1000 -%}{%- assign ws_price_cents = ws_price | times: 100 -%}
      {%- else -%}{%- assign ws_price_cents = ws_price -%}{%- endif -%}
      wholesalePriceMap['{{ item.product.id }}'] = {{ ws_price_cents | json }};
    {%- endif -%}
  {%- endfor -%}

  var minQty = {{ settings.conectwhats_atacado_min_qty | default: 6 | json }};

  function calcAndUpdateTotal() {
    fetch('/cart.js')
      .then(function(r) { return r.json(); })
      .then(function(cart) {
        if (cart.item_count < minQty) return;

        var wholesaleTotal = 0;
        var originalTotal = 0;
        var hasWholesale = false;

        cart.items.forEach(function(item) {
          var pid = String(item.product_id);
          var wsPrice = wholesalePriceMap[pid];
          originalTotal += item.final_line_price;
          if (wsPrice) {
            wholesaleTotal += wsPrice * item.quantity;
            hasWholesale = true;
          } else {
            wholesaleTotal += item.final_line_price;
          }
        });

        if (!hasWholesale || wholesaleTotal >= originalTotal) return;

        // Atualiza total do mini-cart
        var miniCartTotal = document.getElementById('mini-cart-total-price');
        if (miniCartTotal) {
          miniCartTotal.innerHTML =
            '<div style="margin-bottom:2px;"><span style="text-decoration:line-through;color:#9CA3AF;font-size:13px;">' + formatMoney(originalTotal) + '</span></div>' +
            '<span style="color:#16A34A;font-weight:700;font-size:17px;">' + formatMoney(wholesaleTotal) + '</span>';
        }

        // Atualiza total da página do carrinho
        var cartTotal = document.getElementById('cart-total-original');
        if (cartTotal) {
          cartTotal.innerHTML =
            '<div style="margin-bottom:2px;"><span style="text-decoration:line-through;color:#9CA3AF;font-size:14px;">' + formatMoney(originalTotal) + '</span></div>' +
            '<span style="color:#16A34A;font-weight:700;font-size:20px;">' + formatMoney(wholesaleTotal) + '</span>';
        }
      });
  }

  setTimeout(calcAndUpdateTotal, 200);
  document.addEventListener('product:added', function() { setTimeout(calcAndUpdateTotal, 500); });
  document.addEventListener('cart:refresh', function() { setTimeout(calcAndUpdateTotal, 400); });
})();
</script>
{%- endif -%}
